<Page x:Class="OrderSystem.Views.Management.ReceiptManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:OrderSystem.Views.Management"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="700"
      Title="ReceiptManagementPage">

    <Grid x:Name="PrintBtn">
        <TextBox 
            x:Name="ReceiptIdTxtBox" 
            HorizontalAlignment="Left" 
            Margin="147,16,0,0" 
            TextWrapping="Wrap" 
            VerticalAlignment="Top" 
            Width="140" Height="40"/>


        <Button 
            x:Name="SearchBtn"
            Content="検索" 
            HorizontalAlignment="Left" 
            Margin="334,16,0,0" 
            VerticalAlignment="Top" 
            IsDefault="True"
            Height="40" 
            Width="60" 
            Click="SearchBtn_Click"/>

        <Button 
            x:Name="PrntBtn"
            Content="印刷" 
            HorizontalAlignment="Left" 
            Margin="420,16,0,0" 
            VerticalAlignment="Top" 
            Height="40" 
            Width="60" 
            Click="PrntBtn_Click" />

        <Button 
            x:Name="ClearBtn"
            Content="クリア" 
            HorizontalAlignment="Left" 
            Margin="504,16,0,0" 
            VerticalAlignment="Top" 
            Height="40" 
            Width="60" Click="ClearBtn_Click"/>



        <Button 
            x:Name="BackBtn"
            Content="戻る" 
            HorizontalAlignment="Left" 
            Margin="600,16,0,0" 
            VerticalAlignment="Top" 
            Height="40" 
            Width="60" Click="BackBtn_Click"/>


        <DataGrid 
            x:Name="ListDataGrid"  
            Margin="50,78,306,92"
            AutoGenerateColumns="False">

            <DataGrid.Columns>

                <DataGridTextColumn 
                    Header="商品" 
                    Binding="{Binding ProductName}" 
                    Width="120"/>

                <DataGridTextColumn 
                    Header="単価" 
                    Binding="{Binding Price}" 
                    Width="*"/>

                <DataGridTextColumn 
                    Header="個数"   
                    Binding="{Binding Quantity}" 
                    Width="*"/>

                <DataGridTextColumn 
                    Header="合計"   
                    Binding="{Binding Subtotal}" 
                    Width="*"/>


            </DataGrid.Columns>

        </DataGrid>


        <DataGrid 
            x:Name="OrderDataGrid"  
            Margin="420,78,40,92"
            AutoGenerateColumns="False">

            <DataGrid.Columns>

                <DataGridTextColumn 
                    Header="注文ID" 
                    Binding="{Binding OrderId}" 
                    Width="45"/>

                <DataGridTextColumn 
                    Header="日時" 
                    Binding="{Binding DateTime}" 
                    Width="120"/>

                <DataGridTextColumn 
                    Header="合計"   
                    Binding="{Binding TotalAmount}" 
                    Width="*"/>

            </DataGrid.Columns>

        </DataGrid>



        <TextBlock 
            x:Name="TotalSumTxtBlock" 
            HorizontalAlignment="Center" 
            Margin="0,358,0,0" 
            TextWrapping="Wrap" 
            Text="合計: ¥0" 
            FontSize="20"
            VerticalAlignment="Top" 
            Height="30" Width="140"/>

        <TextBlock 
            HorizontalAlignment="Left" 
            Margin="50,21,0,0" 
            TextWrapping="Wrap" 
            Text="注文ID：" 
            VerticalAlignment="Top" 
            Height="30" Width="77"
            FontSize="14"
            TextAlignment="Center"/>







    </Grid>
</Page>
