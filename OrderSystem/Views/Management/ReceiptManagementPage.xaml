<Page x:Class="OrderSystem.Views.Management.ReceiptManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:OrderSystem.Views.Management"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="700"
      Title="ReceiptManagementPage"
      Background="#FFF0F4F8">

    <Grid>
        <Border Background="#FF2C3E50" Height="50" VerticalAlignment="Top">
            <TextBlock Text="レシート管理" 
                       Foreground="White" FontSize="22" FontWeight="Bold"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <TextBlock Text="注文ID：" FontSize="14" 
                   HorizontalAlignment="Left" Margin="50,70,0,0"
                   Foreground="#FF2C3E50" VerticalAlignment="Top"/>

        <TextBox x:Name="ReceiptIdTxtBox" 
                 HorizontalAlignment="Left" Margin="147,68,0,0" 
                 VerticalAlignment="Top" Width="140" Height="35"/>

        <Button x:Name="SearchBtn" Content="検索" 
                HorizontalAlignment="Left" Margin="300,67,0,0" 
                VerticalAlignment="Top" Height="35" Width="60"
                Background="#FF2980B9" IsDefault="True"
                Click="SearchBtn_Click"/>

        <Button x:Name="PrntBtn" Content="印刷" 
                HorizontalAlignment="Left" Margin="370,68,0,0" 
                VerticalAlignment="Top" Height="35" Width="60"
                Background="#FF27AE60" Click="PrntBtn_Click" />

        <Button x:Name="ClearBtn" Content="クリア" 
                HorizontalAlignment="Left" Margin="440,68,0,0" 
                VerticalAlignment="Top" Height="35" Width="60"
                Background="#FF95A5A6" Click="ClearBtn_Click"/>

        <Button x:Name="BackBtn" Content="← 戻る" 
                HorizontalAlignment="Left" Margin="20,10,0,0" 
                VerticalAlignment="Top" Height="35" Width="70"
                Background="#FF95A5A6" Click="BackBtn_Click"/>

        <DataGrid x:Name="ListDataGrid"  
                  Margin="15,110,340,50"
                  AutoGenerateColumns="False"
                  Background="White" RowHeight="28">
            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#FF2C3E50"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Height" Value="30"/>
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="商品" 
                                    Binding="{Binding ProductName}" Width="120"/>
                <DataGridTextColumn Header="単価" 
                                    Binding="{Binding Price}" Width="*"/>
                <DataGridTextColumn Header="個数"   
                                    Binding="{Binding Quantity}" Width="*"/>
                <DataGridTextColumn Header="合計"   
                                    Binding="{Binding Subtotal}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <DataGrid x:Name="OrderDataGrid"  
                  Margin="380,110,15,50"
                  AutoGenerateColumns="False"
                  Background="White" RowHeight="28">
            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#FF2C3E50"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Height" Value="30"/>
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="注文ID" 
                                    Binding="{Binding OrderId}" Width="60"/>
                <DataGridTextColumn Header="日時" 
                                    Binding="{Binding DateTime}" Width="140"/>
                <DataGridTextColumn Header="合計"   
                                    Binding="{Binding TotalAmount}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Background="White" CornerRadius="6"
                HorizontalAlignment="Left" Margin="220,0,0,10"
                VerticalAlignment="Bottom" Width="140" Height="32">
            <TextBlock x:Name="TotalSumTxtBlock" Text="合計: ¥0" 
                       FontSize="16" FontWeight="Bold"
                       Foreground="#FF2C3E50"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Page>