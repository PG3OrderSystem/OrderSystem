<Page x:Class="OrderSystem.Views.Management.TopManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:OrderSystem.Views.Management"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="700"
      Title="TopManagementPage">

    <Grid>

        <Button 
            x:Name="ProductManagementBtn" 
            Content="商品管理" 
            HorizontalAlignment="Left" 
            Margin="80,0,0,0" 
            Height="120" Width="170" Click="ProductManagementBtn_Click"/>


        <Button 
            x:Name="ReceiptManagementBtn" 
            Content="レシート管理" 
            HorizontalAlignment="Left" 
            Margin="450,0,0,0" 
            Height="120" Width="170" 
            Click="ReceiptManagementBtn_Click"/>












    </Grid>
</Page>
