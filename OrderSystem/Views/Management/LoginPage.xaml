<Page x:Class="OrderSystem.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:OrderSystem.Views"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="700"
      Title="LoginPage"
      Background="#FFF0F4F8">

    <Grid>
        <Border Background="#FF2C3E50" Height="50" VerticalAlignment="Top">
            <TextBlock Text="管理者ログイン" 
                       Foreground="White"
                       FontSize="22" FontWeight="Bold"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <Border Background="White" CornerRadius="10"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="300" Height="320" Padding="25">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Admin ID" FontSize="13" Foreground="#FF7F8C8D" Margin="0,0,0,5"/>
                <TextBox x:Name="AdminTxtBox" FontSize="16" Height="40"
                         BorderBrush="#FFDDDDDD" Background="#FFF9F9F9"/>

                <TextBlock Text="Password" FontSize="13" Foreground="#FF7F8C8D" Margin="0,15,0,5"/>
                <PasswordBox x:Name="PassTxtBox" PasswordChar="•"
                             FontSize="16" Height="40"
                             BorderBrush="#FFDDDDDD" Background="#FFF9F9F9"/>

                <Button x:Name="LoginBtn" Content="ログイン" 
                        Margin="0,20,0,0" Height="45"
                        Background="#FF4A90D9" IsDefault="True"
                        Click="LoginBtn_Click"/>

                <Button x:Name="CancelBtn" Content="キャンセル" 
                        Margin="0,10,0,0" Height="45"
                        Background="#FF95A5A6"
                        Click="CancelBtn_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>