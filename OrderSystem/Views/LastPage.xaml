<Page x:Class="OrderSystem.Views.LastPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:OrderSystem.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="700"
      Title="LastPage">

    <Grid>


        <DataGrid 
            x:Name="ListDataGrid"  
            Margin="50,78,50,92"
            AutoGenerateColumns="False">

            <DataGrid.Columns>

                <DataGridTextColumn 
                    Header="商品" 
                    Binding="{Binding ProductName}" 
                    Width="*"/>

                <DataGridTextColumn 
                    Header="単価" 
                    Binding="{Binding Price}" 
                    Width="*"/>

                <DataGridTextColumn 
                    Header="個数"   
                    Binding="{Binding Quantity}" 
                    Width="*"/>

                <DataGridTextColumn 
                    Header="合計"   
                    Binding="{Binding Subtotal}" 
                    Width="*"/>


            </DataGrid.Columns>

        </DataGrid>


        <Button 
            x:Name="BackBtn" 
            Content="🔙" 
            HorizontalAlignment="Left" 
            Margin="20,20,0,0" 
            VerticalAlignment="Top" 
            Width="30" Height="20" Click="BackBtn_Click"/>


        <TextBlock 
            x:Name="TotalSumTxtBlock" 
            HorizontalAlignment="Left" 
            Margin="499,360,0,0" 
            TextWrapping="Wrap" 
            Text="合計: ¥0" 
            FontSize="20"
            VerticalAlignment="Top" 
            Height="30" Width="140"/>
        
        
        <TextBlock 
            x:Name="OrderIdTxtBlock" 
            HorizontalAlignment="Left" 
            Margin="159,20,0,0" 
            TextWrapping="Wrap" 
            Text="注文ID：" 
            VerticalAlignment="Top"/>

    </Grid>
</Page>
