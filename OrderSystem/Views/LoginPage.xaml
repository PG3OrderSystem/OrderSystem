<Page x:Class="OrderSystem.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:OrderSystem.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="700"
      Title="LoginPage">

    <Grid>

        <TextBlock 
            HorizontalAlignment="Left" 
            Margin="190,89,0,0" 
            TextWrapping="Wrap" 
            Text="Admin" 
            VerticalAlignment="Top" 
            FontSize="16"/>
        <TextBox 
            x:Name="AdminTxtBox"
            HorizontalAlignment="Center" 
            Margin="0,80,0,0" 
            TextWrapping="Wrap" 
            VerticalAlignment="Top" 
            Width="150" Height="40"/>





        <TextBlock 
            HorizontalAlignment="Left" 
            Margin="170,169,0,0" 
            TextWrapping="Wrap" 
            Text="Password" 
            VerticalAlignment="Top" 
            FontSize="16"/>
        <PasswordBox 
            x:Name="PassTxtBox"
            PasswordChar="•"
            HorizontalAlignment="Center" 
            Margin="0,160,0,0" 
            VerticalAlignment="Top" 
            Width="150" Height="40"/>


        
        
        
        
        <Button 
            x:Name="LoginBtn" 
            Content="Login" 
            HorizontalAlignment="Center" 
            Margin="0,238,0,0" 
            VerticalAlignment="Top" 
            Height="50" Width="100" 
            Click="LoginBtn_Click"/>

        <Button 
            x:Name="CancelBtn" 
            Content="Cancel" 
            HorizontalAlignment="Center" 
            Margin="0,320,0,0" 
            VerticalAlignment="Top" 
            Height="50" Width="100" 
            Click="CancelBtn_Click"/>














    </Grid>
</Page>
