<Page x:Class="OrderSystem.Views.TopPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:OrderSystem.Views"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="700"
      Title="TopPage"
      Background="#FFF0F4F8">

    <Grid>
        <Border Background="#FF2C3E50" Height="50" VerticalAlignment="Top">
            <Grid>
                <TextBlock Text="OIC食堂" 
                           Foreground="White"
                           FontSize="22" 
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Center" 
                            Margin="0,0,10,0">
                    <Button x:Name="CallStaffBtn" Content="店員呼出し" 
                            Height="30" Width="100" Margin="0,0,5,0"
                            Background="#FFE74C3C" Click="CallStaffBtn_Click"/>
                    <Button x:Name="ManagementBtn" Content="管理" 
                            Height="30" Width="70"
                            Background="#FF95A5A6" Click="ManagementBtn_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Margin="0,50,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="285"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Top" Margin="20,20,0,0">
                <Button x:Name="SetBtn" Content="🍽️ セット" 
                        FontSize="10"
                        Height="50" Width="80" Margin="0,0,0,10"
                        Background="#FFE67E22" Click="SetBtn_Click"/>
                <Button x:Name="SingleBtn" Content="🍛 単品" 
                        FontSize="10"
                        Height="50" Width="80" Margin="0,0,0,10"
                        Background="#FF27AE60" Click="SingleBtn_Click"/>
                <Button x:Name="DrinkBtn" Content="🥤 ドリンク" 
                        FontSize="10"
                        Height="50" Width="80" Margin="0,0,0,10"
                        Background="#FF2980B9" Click="DrinkBtn_Click"/>
                <Button x:Name="SideBtn" Content="🍟 サイド" 
                        FontSize="10"
                        Height="50" Width="80"
                        Background="#FF8E44AD" Click="SideBtn_Click"/>
            </StackPanel>

            <ContentControl Grid.Column="1" x:Name="MiddleContent"
                            Margin="5,20,10,20"/>

            <Grid Grid.Column="2" Margin="0,20,15,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid x:Name="ListDataGrid"  
                          Grid.Row="0"
                          AutoGenerateColumns="False"
                          Background="White" RowHeight="30">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#FF2C3E50"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Height" Value="32"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="商品" 
                                            Binding="{Binding ProductName}" Width="110"/>
                        <DataGridTextColumn Header="単価" 
                                            Binding="{Binding Price}" Width="60"/>
                        <DataGridTextColumn Header="個数"   
                                            Binding="{Binding Quantity}" Width="50"/>
                        <DataGridTextColumn Header="小計"   
                                            Binding="{Binding Subtotal}" Width="70"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="1" Margin="0,10,0,0" HorizontalAlignment="Center">
                    <Border Background="White" CornerRadius="6"
                            HorizontalAlignment="Center" Width="160" Height="28"
                            Margin="0,0,0,10">
                        <TextBlock x:Name="TotalSumTxtBlock" Text="合計: ¥0" 
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="#FF2C3E50"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="ClearBtn" Content="全削除" 
                                Height="34" Width="70" Margin="0,0,10,0"
                                Background="#FFE74C3C" Click="ClearBtn_Click"/>
                        <Button x:Name="OrderBtn" Content="注文確定" 
                                Height="34" Width="85"
                                Background="#FF27AE60" Click="OrderBtn_Click"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
