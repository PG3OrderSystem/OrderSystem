<Page x:Class="OrderSystem.Views.TopPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:OrderSystem.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="700"
      Title="TopPage">

    <Grid>

        <TextBlock 
            HorizontalAlignment="Center" 
            Margin="0,21,0,0" 
            TextWrapping="Wrap" 
            Text="OIC食堂" 
            VerticalAlignment="Top" 
            Height="29" Width="100" 
            TextAlignment="Center" 
            FontSize="20"/>

        <Button 
            x:Name="SetBtn" 
            Content="セット" 
            HorizontalAlignment="Left" 
            Margin="20,79,0,0" 
            VerticalAlignment="Top" 
            Height="50" Width="60" 
            Click="SetBtn_Click"/>

        <Button 
            x:Name="SingleBtn" 
            Content="単品" 
            HorizontalAlignment="Left" 
            Margin="20,159,0,0" 
            VerticalAlignment="Top" 
            Height="50" Width="60" 
            Click="SingleBtn_Click"/>

        <Button 
            x:Name="DrinkBtn" 
            Content="ドリンク" 
            HorizontalAlignment="Left" 
            Margin="20,239,0,0" 
            VerticalAlignment="Top" 
            Height="50" Width="60" 
            Click="DrinkBtn_Click"/>

        <Button 
            x:Name="SideBtn" 
            Content="サイド" 
            HorizontalAlignment="Left" 
            Margin="20,319,0,0" 
            VerticalAlignment="Top" 
            Height="50" 
            Width="60" 
            Click="SideBtn_Click"/>

        <DataGrid 
            x:Name="ListDataGrid"  
            Margin="400,70,30,120"
            AutoGenerateColumns="False">

            <DataGrid.Columns>

                <DataGridTextColumn 
                Header="商品" 
                Binding="{Binding ItemID}" 
                Width="80"/>

                <DataGridTextColumn 
                Header="単価" 
                Binding="{Binding Price}" 
                Width="50"/>

                <DataGridTextColumn 
                Header="個数"   
                Binding="{Binding Quantity}" 
                Width="35"/>
                <DataGridTextColumn 
                Header="小計"   
                Binding="{Binding Subtotal}" 
                Width="*"/>




            </DataGrid.Columns>
        </DataGrid>

        <Button 
            x:Name="CallStaffBtn"
            Content="店員呼出し" 
            HorizontalAlignment="Left" 
            Margin="520,20,0,0" 
            VerticalAlignment="Top" 
            Height="30" Width="70" 
            Click="CallStaffBtn_Click"/>

        <Button 
            x:Name="ManagementBtn"
            Content="管理" 
            HorizontalAlignment="Left" 
            Margin="600,20,0,0" 
            VerticalAlignment="Top" 
            Height="30" Width="70" 
            Click="ManagementBtn_Click" />


        <TextBlock 
            x:Name="TotalSumTxtBlock" 
            HorizontalAlignment="Left" 
            Margin="538,318,0,0" 
            TextWrapping="Wrap" 
            Text="合計：" 
            VerticalAlignment="Top" 
            Width="120" Height="25"/>


        <Button 
            x:Name="ClearBtn" 
            Content="全削除" 
            HorizontalAlignment="Left" 
            Margin="446,350,0,0" 
            VerticalAlignment="Top"
            Height="30" Width="60" 
            Click="ClearBtn_Click"/>

        <Button 
            x:Name="OrderBtn" 
            Content="注文確定" 
            HorizontalAlignment="Left" 
            Margin="615,350,0,0" 
            VerticalAlignment="Top"
            Height="30" Width="60" 
            Click="OrderBtn_Click"/>



        <ContentControl 
            x:Name="MiddleContent"
            Margin="90,74,310,66" 
            Width="300"/>







    </Grid>
</Page>
