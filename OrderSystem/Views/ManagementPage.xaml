<Page x:Class="OrderSystem.Views.ManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:OrderSystem.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="700"
      Title="ManagementPage">

    <Grid>

        <TextBlock 
            HorizontalAlignment="Left" 
            Margin="295,30,0,0" 
            TextWrapping="Wrap" 
            Text="商品一覧" 
            VerticalAlignment="Top" 
            Height="30" Width="80"/>


        <DataGrid 
            x:Name="dataGridProducts"  
            Margin="50,150,50,20"
            AutoGenerateColumns="False">

            <DataGrid.Columns>

                <DataGridTextColumn 
                    Header="商品ID" 
                    Binding="{Binding ProductId}" 
                    Width="100"/>

                <DataGridTextColumn 
                    Header="商品" 
                    Binding="{Binding ProductName}" 
                    Width="100"/>

                <DataGridTextColumn 
                    Header="単価" 
                    Binding="{Binding Price}" 
                    Width="100"/>

                <DataGridTextColumn 
                    Header="カテゴリー"   
                    Binding="{Binding Category}" 
                    Width="*"/>

            </DataGrid.Columns>

        </DataGrid>


        <Button 
            x:Name="TopPageBtn" 
            Content="TopPage" 
            HorizontalAlignment="Left" 
            Margin="30,30,0,0" 
            VerticalAlignment="Top" 
            Width="80" Height="40" 
            Click="TopPageBtn_Click" />

    </Grid>
</Page>
